{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "baseBranchPatterns": [
    "main"
  ],
  "timezone": "America/Los_Angeles",
  "dependencyDashboard": true,
  "platformAutomerge": true,
  "major": {
    "dependencyDashboardApproval": true
  },
  "minimumReleaseAge": "14 days",
  "prConcurrentLimit": 5,
  "branchConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rangeStrategy": "replace",
  "labels": [
    "dependencies"
  ],
  "vulnerabilityAlerts": {
    "labels": [
      "dependencies",
      "security"
    ],
    "dependencyDashboardApproval": false,
    "minimumReleaseAge": null
  },
  "packageRules": [
    {
      "description": "Automerge non-major GitHub Actions updates after required checks pass",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "groupName": "github actions non-major dependencies",
      "automerge": true,
      "automergeType": "pr",
      "labels": [
        "dependencies"
      ]
    },
    {
      "description": "Require dashboard approval for major GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true,
      "labels": [
        "dependencies",
        "major-update"
      ]
    }
  ]
}
